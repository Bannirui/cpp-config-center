{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "user-debug",
      "inherits": "debug",
      "displayName": "User Debug",
      "description": "Override base paths here for your machine — this file is gitignored",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "/custom/path/here"
      },
      "environment": {
        "http_proxy": "http://127.0.0.1:7890",
        "https_proxy": "http://127.0.0.1:7890"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "user-debug",
      "configurePreset": "user-debug",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "user-debug",
      "configurePreset": "user-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
